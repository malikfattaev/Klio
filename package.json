{
  "name": "klio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @klio/web dev",
    "build": "pnpm --filter @klio/web build",
    "start": "pnpm --filter @klio/web start",
    "lint": "pnpm --filter @klio/web lint",
    "typecheck": "pnpm --filter @klio/web typecheck",
    "db:generate": "pnpm --filter @klio/web db:generate",
    "db:migrate": "pnpm --filter @klio/web db:migrate",
    "db:studio": "pnpm --filter @klio/web db:studio"
  }
}
